datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?
  image                 String?
  accounts              Account[]
  sessions              Session[]
  watchlistSymbols      WatchlistSymbol[]
  trading212Connection  Trading212Connection?
  portfolioHoldings     PortfolioHolding[]
}

enum Trading212Environment {
  demo
  live
}

enum PortfolioHoldingSource {
  manual
  t212
}

model Trading212Connection {
  id           String                  @id @default(cuid())
  userId       String                  @unique
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  environment  Trading212Environment   @default(demo)
  apiKeyEnc    String                  @db.Text
  apiSecretEnc String                  @db.Text
  lastSyncAt   DateTime?
  lastError    String?                 @db.Text
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
}

model PortfolioHolding {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbolYahoo String
  symbolT212  String?
  quantity    Decimal                @db.Decimal(20, 8)
  avgPrice    Decimal                @db.Decimal(20, 8)
  currency    String                 @default("USD")
  source      PortfolioHoldingSource
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([userId, symbolYahoo, source])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WatchlistSymbol {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
  @@index([userId])
}

/** Cached Gemini stock bundle (DB first; refresh after TTL). */
model StockAnalysisCache {
  symbol    String   @id
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
